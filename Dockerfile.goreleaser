# Release image: copies the prebuilt GoReleaser binary (no builder stage, so there is
# no builder to COPY a CA bundle from). distroless/static:nonroot already bundles
# ca-certificates and runs as a non-root user (65532:65532) — no `apk add` needed.
FROM gcr.io/distroless/static:nonroot
COPY veeam_licenses_exporter /usr/local/bin/veeam_licenses_exporter
COPY config.yaml /etc/veeam_licenses_exporter/config.yaml
EXPOSE 9107
ENTRYPOINT ["/usr/local/bin/veeam_licenses_exporter"]
CMD ["--config", "/etc/veeam_licenses_exporter/config.yaml"]
